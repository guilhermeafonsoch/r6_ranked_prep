generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RankBand {
  COPPER_BRONZE
  SILVER_GOLD
  PLATINUM_EMERALD
  DIAMOND_CHAMPION
  ALL
}

enum Side {
  ATTACK
  DEFENSE
}

enum SideType {
  ATTACK
  DEFENSE
  FLEX
}

enum Difficulty {
  LOW
  MEDIUM
  HIGH
}

enum PlanType {
  SAFE
  AGGRESSIVE
  FALLBACK
}

enum Phase {
  SETUP
  EXECUTION
  CONTINGENCY
}

model User {
  id                   String         @id @default(cuid())
  email                String         @unique
  displayName          String
  rankBand             RankBand       @default(SILVER_GOLD)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  ownedSquads          Squad[]        @relation("SquadOwner")
  squadMemberships     SquadMember[]
  createdStrategyCards StrategyCard[] @relation("StrategyCardCreator")
  notes                SavedNote[]
}

model Squad {
  id            String         @id @default(cuid())
  ownerId       String
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  owner         User           @relation("SquadOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       SquadMember[]
  notes         SavedNote[]
  playbookCards PlaybookCard[]
}

model SquadMember {
  id               String   @id @default(cuid())
  squadId          String
  userId           String?
  nickname         String
  preferredRoles   Json
  comfortOperators Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  squad            Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Map {
  id         String       @id @default(cuid())
  slug       String       @unique
  name       String
  inRotation Boolean      @default(true)
  seasonTag  String
  imageUrl   String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  sites      Site[]
  banRules   BanRule[]
  strategies StrategyCard[]
  notes      SavedNote[]
  playbooks  PlaybookCard[]
}

model Site {
  id         String         @id @default(cuid())
  mapId      String
  slug       String
  name       String
  sideType   SideType
  difficulty Difficulty
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  map        Map            @relation(fields: [mapId], references: [id], onDelete: Cascade)
  strategies StrategyCard[]
  notes      SavedNote[]
  playbooks  PlaybookCard[]

  @@unique([mapId, slug])
}

model Operator {
  id         String     @id @default(cuid())
  slug       String     @unique
  name       String
  side       Side
  roleTags   Json
  difficulty Difficulty
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model StrategyCard {
  id                   String         @id @default(cuid())
  mapId                String
  siteId               String
  side                 Side
  title                String
  description          String
  planType             PlanType
  teamSize             Int
  recommendedOperators Json
  roleAssignments      Json
  watchouts            Json
  createdBy            String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  map                  Map            @relation(fields: [mapId], references: [id], onDelete: Cascade)
  site                 Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  creator              User?          @relation("StrategyCardCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  steps                StrategyStep[]

  @@unique([siteId, side, planType])
}

model StrategyStep {
  id             String       @id @default(cuid())
  strategyCardId String
  stepOrder      Int
  phase          Phase
  text           String
  strategyCard   StrategyCard @relation(fields: [strategyCardId], references: [id], onDelete: Cascade)

  @@unique([strategyCardId, phase, stepOrder])
}

model BanRule {
  id           String    @id @default(cuid())
  mapId        String
  rankBand     RankBand
  attackBan    String
  defenseBan   String
  rationale    String
  fallbackBans Json
  weight       Int       @default(100)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  map          Map       @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@unique([mapId, rankBand])
}

model PatchNote {
  id                  String   @id @default(cuid())
  seasonTag           String
  title               String
  summary             String
  tacticalImplication String
  publishedAt         DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model MapRotationEvent {
  id            String   @id @default(cuid())
  seasonTag     String
  effectiveDate DateTime
  addedMaps     Json
  removedMaps   Json
  notes         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SavedNote {
  id        String   @id @default(cuid())
  userId    String
  squadId   String?
  mapId     String
  siteId    String
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  squad     Squad?   @relation(fields: [squadId], references: [id], onDelete: SetNull)
  map       Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model PlaybookCard {
  id            String   @id @default(cuid())
  squadId       String
  mapId         String
  siteId        String
  title         String
  summary       String
  preferredComp Json
  assignedRoles Json
  checklist     Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  squad         Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  map           Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
}
